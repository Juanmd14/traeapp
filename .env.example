# ============================================
# WHATSAPP CLOUD API (Meta) - opcional
# Setup: Meta Business → WhatsApp → API Setup
# Template "nuevo_pedido" (UTILITY, es_MX) con 4 variables:
#   {{1}} storeName  {{2}} orderNumber  {{3}} totalLabel  {{4}} panelUrl
# Si quedan vacías, los avisos por WhatsApp no se mandan (la app sigue funcionando).
# ============================================
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TEMPLATE_NAME=nuevo_pedido
META_WHATSAPP_TEMPLATE_LANG=es_MX



